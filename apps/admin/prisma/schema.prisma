  strategyId   Int      @map("strategy_id")
  startDate    DateTime @map("start_date") @db.Date
  endDate      DateTime @map("end_date") @db.Date
  initialValue Decimal  @map("initial_value") @db.Decimal(18, 2)
  finalValue   Decimal  @map("final_value") @db.Decimal(18, 2)
  roiPct       Decimal  @map("roi_pct") @db.Decimal(9, 4)
  maxDrawdown  Decimal  @map("max_drawdown") @db.Decimal(9, 4)
  sharpeRatio  Decimal? @map("sharpe_ratio") @db.Decimal(7, 4)
  resultData   Json?    @map("result_data")
  createdAt    DateTime @default(now()) @map("created_at")

  strategy StrategyTemplate @relation(fields: [strategyId], references: [id], onDelete: Cascade)

  @@index([strategyId])
  @@map("backtest_results")
}

// ─── 20) Invoices ───────────────────────────────────────

model Invoice {
  id            Int           @id @default(autoincrement())
  paymentId     Int           @unique @map("payment_id")
  userId        Int           @map("user_id")
  invoiceNumber String        @unique @map("invoice_number") @db.VarChar(50)
  subtotal      Decimal       @db.Decimal(12, 2)
  tax           Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount   Decimal       @map("total_amount") @db.Decimal(12, 2)
  status        InvoiceStatus @default(draft)
  issuedAt      DateTime?     @map("issued_at")
  paidAt        DateTime?     @map("paid_at")
  createdAt     DateTime      @default(now()) @map("created_at")

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("invoices")
}
